# ============================================================
# Qubi — variables de PRODUCCIÓN (copiar a `.env` EN EL VPS, no commitear).
# Reemplaza tudominio.com y todas las contraseñas.
# ============================================================

# ── Base de datos (contenedor postgres del compose) ─────────────────────────
POSTGRES_USER=qubi
POSTGRES_PASSWORD=CAMBIA_esta_contraseña
POSTGRES_DB=qubi
DATABASE_URL="postgresql://qubi:CAMBIA_esta_contraseña@postgres:5432/qubi?schema=public"

# ── Almacenamiento de archivos (contenedor minio) ───────────────────────────
S3_ENDPOINT="http://minio:9000"                      # interno: la app sube aquí
S3_PUBLIC_URL="https://qubi.tudominio.com/files"     # público: lo que ve el navegador
S3_ACCESS_KEY=qubi
S3_SECRET_KEY=CAMBIA_esta_clave
S3_BUCKET=qubi-uploads
S3_REGION=us-east-1

# ── Colaboración en tiempo real (Hocuspocus) ────────────────────────────────
COLLAB_PORT=1234
# ⚠️ Se incrusta en build time (build-arg). El navegador se conecta aquí.
NEXT_PUBLIC_COLLAB_URL="wss://qubi.tudominio.com/collab"

# ── Autenticación (Auth.js) ─────────────────────────────────────────────────
# Genera el secreto con:  openssl rand -base64 32
AUTH_SECRET="CAMBIA_genera_uno_seguro"
NEXTAUTH_URL="https://qubi.tudominio.com"
# Detrás de un reverse proxy (nginx) hay que confiar en el Host reenviado.
AUTH_TRUST_HOST=true
# Opcional — Google OAuth (déjalo vacío si no lo usas todavía):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
