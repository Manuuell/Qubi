// Esquema de datos de Qubi.
// Docs: https://pris.ly/d/prisma-schema
// La URL de conexión se configura en prisma.config.ts (lee DATABASE_URL del .env).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum PageType {
  PAGE
  DATABASE
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

// Prioridad de una tarea.
enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ── Usuarios ─────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  hashedPassword String? // login con email/contraseña (Fase 1)
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships     WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  createdPages    Page[]            @relation("PageCreatedBy")
  accounts        Account[]
  sessions        Session[]
  favorites       Favorite[]
  authoredIssues  Issue[]        @relation("IssueAuthor")
  assignedIssues  Issue[]        @relation("IssueAssignee")
  issueComments   IssueComment[] @relation("IssueCommentAuthor")
  timeEntries     TimeEntry[]
}

// ── Auth.js (NextAuth) ───────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── Workspaces (espacios de trabajo) ─────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  icon      String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  pages    Page[]
  issues   Issue[]
  projects Project[]

  @@index([ownerId])
}

// ── Proyectos (agrupan tareas y horas de trabajo) ────────────────────────
model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String        @default("")
  color       String? // color para la UI (hex)
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Issue[] // las tareas del proyecto (modelo Issue)
  timeEntries TimeEntry[]

  @@index([workspaceId])
}

// Tabla puente usuario <-> workspace (con su rol).
model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ── Páginas (contenido; anidables en árbol) ──────────────────────────────

model Page {
  id          String    @id @default(cuid())
  workspaceId String
  parentId    String? // null = página de primer nivel
  databaseId  String? // si está, esta página es una FILA de esa base de datos
  title       String    @default("")
  icon        String?
  cover       String?
  type        PageType  @default(PAGE)
  content     Json? // documento de bloques (JSON; legado pre-Yjs)
  yjsState    Bytes? // documento Yjs (binario) para edición colaborativa en tiempo real
  isPublic    Boolean   @default(false) // enlace público de solo lectura
  archivedAt  DateTime? // papelera (soft-delete)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Page?     @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[]    @relation("PageTree")
  createdBy User?     @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Bases de datos tipo Notion
  database           Page?              @relation("DatabaseRows", fields: [databaseId], references: [id], onDelete: Cascade)
  rows               Page[]             @relation("DatabaseRows")
  databaseProperties DatabaseProperty[] @relation("DatabaseProperties")
  propertyValues     PropertyValue[]    @relation("RowValues")
  favoritedBy        Favorite[]

  @@index([workspaceId])
  @@index([parentId])
  @@index([databaseId])
}

// Página marcada como favorita por un usuario.
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([userId, pageId])
  @@index([userId])
}

// ── Issues (seguimiento estilo GitHub) ───────────────────────────────────────

enum IssueStatus {
  TODO
  IN_PROGRESS
  DONE
}

// Tarea / pendiente. Pertenece a un workspace y (opcionalmente) a un proyecto.
model Issue {
  id          String      @id @default(cuid())
  workspaceId String
  projectId   String? // proyecto al que pertenece (null = sin clasificar)
  number      Int // secuencial por espacio (#1, #2, …)
  title       String
  body        String      @default("")
  status      IssueStatus @default(TODO)
  priority    Priority    @default(MEDIUM)
  dueDate     DateTime? // fecha límite (alimenta la agenda y el calendario)
  completedAt DateTime? // momento en que se marcó como HECHA
  authorId    String?
  assigneeId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User?          @relation("IssueAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  assignee    User?          @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    IssueComment[]
  timeEntries TimeEntry[]

  @@unique([workspaceId, number])
  @@index([workspaceId])
  @@index([projectId])
  @@index([assigneeId])
}

// Registro de horas de trabajo de un usuario en un proyecto, por día.
model TimeEntry {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  issueId   String? // opcional: horas imputadas a una tarea concreta
  date      DateTime @db.Date // el día trabajado (sin hora)
  minutes   Int // duración en minutos (1 h 30 min = 90)
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue   Issue?  @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([userId, date])
  @@index([issueId])
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User? @relation("IssueCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([issueId])
}

enum PropertyType {
  TEXT
  NUMBER
  SELECT
  DATE
  CHECKBOX
}

// Columna de una base de datos (la base de datos es una Page con type=DATABASE).
model DatabaseProperty {
  id         String       @id @default(cuid())
  databaseId String
  name       String
  type       PropertyType @default(TEXT)
  position   Int          @default(0)
  config     Json? // opciones de SELECT, formato, etc.
  createdAt  DateTime     @default(now())

  database Page            @relation("DatabaseProperties", fields: [databaseId], references: [id], onDelete: Cascade)
  values   PropertyValue[]

  @@index([databaseId])
}

// Valor de una propiedad para una fila concreta.
model PropertyValue {
  id         String @id @default(cuid())
  pageId     String // la fila (Page)
  propertyId String
  value      Json?

  page     Page             @relation("RowValues", fields: [pageId], references: [id], onDelete: Cascade)
  property DatabaseProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([pageId, propertyId])
  @@index([pageId])
}
